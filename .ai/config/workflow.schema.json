{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Workflow Kit Configuration",
  "type": "object",
  "$defs": {
    "hookDef": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "description": "Shell command to execute"
        },
        "timeout": {
          "type": "string",
          "description": "Timeout duration (e.g. '30s', '5m')"
        },
        "on_failure": {
          "enum": ["warn", "abort", "ignore"],
          "default": "warn",
          "description": "Behavior when hook fails: warn (log + continue), abort (stop workflow), ignore (silent)"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Extra environment variables for the hook"
        }
      }
    }
  },
  "required": ["version", "project", "repos", "git"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Configuration version"
    },
    "project": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "type": { "enum": ["monorepo", "single-repo"] }
      }
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "type", "language", "verify"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string" },
          "type": { "enum": ["submodule", "directory", "root"] },
          "language": {
            "enum": [
              "go", "golang",
              "node", "nodejs", "typescript", "javascript",
              "react", "vue", "angular", "nextjs", "nuxt", "svelte",
              "express", "nestjs",
              "python", "django", "flask", "fastapi",
              "rust",
              "dotnet", "csharp", "aspnet", "blazor",
              "unity", "unreal", "ue4", "ue5", "godot",
              "generic"
            ]
          },
          "verify": {
            "type": "object",
            "required": ["build", "test"],
            "properties": {
              "setup": { "type": "string", "description": "Command to install dependencies before build/test (e.g. npm install)" },
              "build": { "type": "string" },
              "test": { "type": "string" }
            }
          },
          "go_version": { "type": "string" },
          "node_version": { "type": "string" },
          "python_version": { "type": "string" },
          "rust_version": { "type": "string" },
          "dotnet_version": { "type": "string" },
          "package_manager": { "enum": ["npm", "yarn", "pnpm"] },
          "godot_version": { "type": "string" },
          "ue_version": { "type": "string" },
          "project_name": { "type": "string" }
        }
      }
    },
    "git": {
      "type": "object",
      "required": ["integration_branch", "release_branch", "commit_format"],
      "properties": {
        "integration_branch": { "type": "string", "minLength": 1 },
        "release_branch": { "type": "string", "minLength": 1 },
        "commit_format": { "type": "string" },
        "pr_body_template": { "type": "string" }
      }
    },
    "specs": {
      "type": "object",
      "properties": {
        "base_path": { "type": "string", "default": ".ai/specs" },
        "files": {
          "type": "object",
          "properties": {
            "requirements": { "type": "string" },
            "design": { "type": "string" },
            "tasks": { "type": "string" }
          }
        },
        "auto_generate_tasks": { "type": "boolean" },
        "active": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tasks": {
      "type": "object",
      "properties": {
        "format": {
          "type": "object",
          "properties": {
            "uncompleted": { "type": "string" },
            "completed": { "type": "string" },
            "optional": { "type": "string" }
          }
        },
        "source_priority": { "type": "array", "items": { "type": "string" } }
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "checks": { "type": "array", "items": { "type": "string" } },
        "custom": { "type": "array", "items": { "type": "string" } }
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "repo": { "type": "string" },
        "labels": {
          "type": "object",
          "properties": {
            "task": { "type": "string" },
            "in_progress": { "type": "string" },
            "pr_ready": { "type": "string" },
            "review_failed": { "type": "string" },
            "worker_failed": { "type": "string" },
            "needs_human_review": { "type": "string" },
            "merge_conflict": { "type": "string", "default": "merge-conflict" },
            "needs_rebase": { "type": "string", "default": "needs-rebase" },
            "completed": { "type": "string", "default": "completed" }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "kit": { "type": "array", "items": { "type": "string" } },
        "custom": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agents": {
      "type": "object",
      "description": "Agent configuration for custom subagents",
      "properties": {
        "builtin": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["pr-reviewer", "conflict-resolver"]
        },
        "custom": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Unique agent name (lowercase, hyphens allowed)"
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "What this agent does"
              },
              "tools": {
                "type": "string",
                "default": "Read, Grep, Glob, Bash",
                "description": "Comma-separated list of allowed tools"
              },
              "model": {
                "enum": ["haiku", "sonnet", "opus"],
                "default": "opus",
                "description": "Model to use for this agent"
              },
              "trigger": {
                "enum": ["review_pr", "check_result", "dispatch_worker", "generate_tasks"],
                "description": "Workflow event that triggers this agent"
              },
              "condition": {
                "type": "string",
                "description": "Optional condition expression for when agent should activate"
              }
            }
          }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "description": "Timeout settings for various operations",
      "properties": {
        "git_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 120,
          "description": "Timeout in seconds for Git operations (fetch, push, rebase)"
        },
        "gh_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 60,
          "description": "Timeout in seconds for GitHub CLI operations (issue view, pr view)"
        },
        "codex_minutes": {
          "type": "integer",
          "minimum": 1,
          "default": 30,
          "description": "Timeout in minutes for Codex Worker execution"
        },
        "gh_retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 3,
          "description": "Maximum retry attempts for gh CLI calls"
        },
        "gh_retry_base_delay": {
          "type": "integer",
          "minimum": 0,
          "default": 2,
          "description": "Base delay in seconds for exponential backoff on gh retries"
        }
      }
    },
    "review": {
      "type": "object",
      "description": "Review and merge settings for PR approval",
      "properties": {
        "score_threshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 7,
          "description": "Minimum review score (1-10) required to approve a PR"
        },
        "merge_strategy": {
          "enum": ["squash", "merge", "rebase"],
          "default": "squash",
          "description": "Git merge strategy used when merging approved PRs"
        },
        "jittest": {
          "type": "object",
          "description": "JiT (Just-in-Time) test generation and execution at review time",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable JiT test generation from PR diffs during review"
            },
            "max_tests": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "default": 5,
              "description": "Maximum number of tests to generate per PR"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 30,
              "maximum": 600,
              "default": 120,
              "description": "Total timeout for JiT test generation and execution"
            },
            "failure_policy": {
              "enum": ["warn", "block"],
              "default": "warn",
              "description": "Action on JiT test failure: warn (comment only) or block (fail review)"
            },
            "model": {
              "type": "string",
              "default": "claude-sonnet-4-6",
              "description": "LLM model used for test generation"
            }
          }
        }
      }
    },
    "escalation": {
      "type": "object",
      "description": "Configuration for when Principal should pause and request human intervention",
      "properties": {
        "triggers": {
          "type": "array",
          "description": "Pattern-based triggers for escalation",
          "items": {
            "type": "object",
            "required": ["pattern", "action"],
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern to match against issue/PR content"
              },
              "action": {
                "enum": ["pause_and_ask", "require_human_approval", "notify_only"],
                "description": "Action to take when pattern matches"
              }
            }
          }
        },
        "max_consecutive_failures": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Maximum consecutive failures before stopping"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 2,
          "description": "Number of retries after a failure"
        },
        "retry_delay_seconds": {
          "type": "integer",
          "minimum": 0,
          "default": 5,
          "description": "Delay between retries in seconds"
        },
        "max_single_pr_files": {
          "type": "integer",
          "minimum": 1,
          "default": 50,
          "description": "Maximum files in a single PR before requiring human review"
        },
        "max_single_pr_lines": {
          "type": "integer",
          "minimum": 1,
          "default": 500,
          "description": "Maximum line changes in a single PR before requiring human review"
        }
      }
    },
    "feedback": {
      "type": "object",
      "description": "Review feedback loop settings for learning from past rejections",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable review feedback recording and injection into Worker prompts"
        },
        "max_history_in_prompt": {
          "type": "integer",
          "minimum": 0,
          "default": 10,
          "description": "Maximum number of historical feedback entries to inject into Worker prompts"
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hooks: run custom shell commands at workflow events",
      "properties": {
        "pre_dispatch": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        },
        "post_dispatch": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        },
        "pre_review": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        },
        "post_review": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        },
        "on_merge": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        },
        "on_failure": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDef" }
        }
      }
    },
    "worker": {
      "type": "object",
      "description": "AI Worker backend configuration",
      "properties": {
        "backend": {
          "enum": ["codex", "claude-code"],
          "default": "codex",
          "description": "AI worker backend to use"
        },
        "codex": {
          "type": "object",
          "properties": {
            "full_auto": {
              "type": "boolean",
              "default": true,
              "description": "Use --full-auto flag for codex"
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Codex-level retry count"
            }
          }
        },
        "claude_code": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "default": "sonnet",
              "description": "Claude model to use (e.g. sonnet, opus, haiku)"
            },
            "max_turns": {
              "type": "integer",
              "minimum": 1,
              "default": 50,
              "description": "Maximum agentic turns for Claude Code"
            },
            "dangerously_skip_permissions": {
              "type": "boolean",
              "default": false,
              "description": "Skip permission prompts (use with caution)"
            }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "PLANNED: Notification support is not yet implemented. This schema is reserved for future use.",
      "deprecated": true,
      "properties": {
        "slack_webhook": { "type": "string" },
        "discord_webhook": { "type": "string" },
        "system_notify": { "type": "boolean" }
      }
    }
  }
}
